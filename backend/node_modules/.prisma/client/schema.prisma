generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  Admin
  Teacher
  Student

  @@map("roles")
}

enum UserStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("user_statuses")
}

enum StudentLevel {
  A1
  A2
  B1
  B2
  C1
  C2

  @@map("student_levels")
}

enum ClassStatus {
  UNDER_REGISTRATION @map("در حال ثبت‌نام")
  ACTIVE             @map("فعال")
  COMPLETED          @map("تکمیل شده")
  CANCELED           @map("لغو شده")

  @@map("class_statuses")
}

enum EnrollmentStatus {
  IN_PROGRESS @map("در حال تحصیل")
  COMPLETED   @map("تکمیل شده")
  DROPPED_OUT @map("انصرافی")

  @@map("enrollment_statuses")
}

enum BookCategory {
  IELTS
  TOEFL
  Conversation
  Grammar
  Vocabulary
  Listening
  Reading
  Writing
  Kids
  General

  @@map("book_categories")
}

enum BookLevel {
  A1
  A2
  B1
  B2
  C1
  C2
  All

  @@map("book_levels")
}

enum BookLanguage {
  Persian
  English
  French
  German
  Arabic

  @@map("book_languages")
}

enum BookStatus {
  AVAILABLE   @map("available")
  UNAVAILABLE @map("unavailable")

  @@map("book_statuses")
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id                   String     @id @default(uuid())
  name                 String     @db.VarChar(100)
  employeeCode         String     @unique @db.VarChar(50)
  password             String     @db.Text
  role                 Role       @default(Student)
  email                String?    @unique @db.VarChar(255)
  phone                String?    @db.Text
  address              String?    @db.Text
  profileImage         String     @default("default-avatar.png") @db.VarChar(255)
  status               UserStatus @default(ACTIVE)
  birthday             String?    @db.VarChar(10)
  passwordChangedAt    DateTime?
  passwordResetToken   String?    @db.Text
  passwordResetExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile  Teacher?
  studentProfile  Student?
  enrollments     Enrollment[]
  teachingClasses Class[]      @relation("ClassTeacher")
  createdClasses  Class[]      @relation("ClassCreatedBy")

  @@index([employeeCode])
  @@index([role])
  @@index([status])
  @@map("users")
}

//////////////////////////////////////////////////////
// TEACHER
//////////////////////////////////////////////////////

model Teacher {
  id             String    @id @default(uuid())
  userId         String    @unique
  specialization String?   @db.Text
  hireDate       DateTime?
  salary         Decimal?  @db.Decimal(12, 2)
  resume         String?   @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("teachers")
}

//////////////////////////////////////////////////////
// STUDENT
//////////////////////////////////////////////////////

model Student {
  id             String       @id @default(uuid())
  userId         String       @unique
  level          StudentLevel @default(A1)
  emergencyPhone String?      @db.Text
  registeredDate DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([level])
  @@map("students")
}

//////////////////////////////////////////////////////
// CLASS
//////////////////////////////////////////////////////

model Class {
  id    String       @id @default(uuid())
  name  String       @db.VarChar(100)
  level StudentLevel @default(A1)

  teacherId String
  teacher   User   @relation("ClassTeacher", fields: [teacherId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  term     String      @db.VarChar(50)
  tuition  Decimal     @default(0) @db.Decimal(12, 2)
  schedule String      @db.VarChar(100)
  room     String      @db.VarChar(50)
  status   ClassStatus @default(UNDER_REGISTRATION)

  createdById String
  createdBy   User   @relation("ClassCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  isConfirmed Boolean   @default(false)
  confirmedAt DateTime?
  startDate   DateTime?
  endDate     DateTime?

  capacity      Int     @default(10)
  totalSessions Int     @default(12)
  description   String? @db.VarChar(500)

  sessions    ClassSession[]
  enrollments Enrollment[]

  @@index([teacherId])
  @@index([createdById])
  @@index([term])
  @@index([level])
  @@index([status])
  @@map("classes")
}

//////////////////////////////////////////////////////
// CLASS SESSION
//////////////////////////////////////////////////////

model ClassSession {
  id            String   @id @default(uuid())
  classId       String
  sessionNumber Int
  date          DateTime
  topic         String?  @db.Text
  isCompleted   Boolean  @default(false)

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([classId, sessionNumber])
  @@index([classId])
  @@map("class_sessions")
}

//////////////////////////////////////////////////////
// ENROLLMENT
//////////////////////////////////////////////////////

model Enrollment {
  id         String           @id @default(uuid())
  userId     String
  classId    String
  enrollDate DateTime         @default(now())
  status     EnrollmentStatus @default(IN_PROGRESS)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, classId])
  @@index([userId])
  @@index([classId])
  @@map("enrollments")
}

//////////////////////////////////////////////////////
// BOOK
//////////////////////////////////////////////////////

model Book {
  id          String       @id @default(uuid())
  productId   Int          @unique
  category    BookCategory
  name        String       @db.VarChar(150)
  level       BookLevel    @default(All)
  price       Decimal      @db.Decimal(12, 2)
  img         String       @db.Text
  stock       Int          @default(0)
  description String?      @db.VarChar(500)
  language    BookLanguage @default(Persian)
  status      BookStatus   @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([level])
  @@index([status])
  @@map("books")
}
